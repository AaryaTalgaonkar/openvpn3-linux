<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE busconfig PUBLIC
 "-//freedesktop//DTD D-BUS Bus Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/busconfig.dtd">
<busconfig>
    <!--
        The bus name scope is shared between the openvpn3-service-backendstart
        and openvpn3-service-client processes.  They all use different
        well-known bus names, but they share the same prefix - starting
        with: net.iitdvpn.backends

        The -backendstart process uses:  net.iitdvpn.backends
        while the -client processes uses: net.iitdvpn.backends.be$PID
    -->

  <policy context="default">
    <allow send_destination="net.iitdvpn.backends"
           send_path="/net/iitdvpn/backends"
           send_interface="org.freedesktop.DBus.Introspectable"
           send_type="method_call"
           send_member="Introspect"/>

    <allow send_destination="net.iitdvpn.backends"
           send_path="/net/iitdvpn/backends"
           send_interface="org.freedesktop.DBus.Properties"
           send_type="method_call"
           send_member="Get"/>

    <allow send_destination="net.iitdvpn.backends"
           send_path="/net/iitdvpn/backends"
           send_interface="org.freedesktop.DBus.Properties"
           send_type="method_call"
           send_member="GetAll"/>

    <allow send_destination="net.iitdvpn.backends"
           send_interface="org.freedesktop.DBus.Peer"
           send_type="method_call"
           send_member="Ping"/>

    <!--
         Only the "@OPENVPN_USERNAME@" user is allowed to
         receive signals from net.iitdvpn.backend interfaces.
    -->
    <deny receive_interface="net.iitdvpn.backends"
          receive_type="signal"/>
  </policy>

  <policy user="@OPENVPN_USERNAME@">
    <!--                                -->
    <!--  net.iitdvpn.backends       -->
    <!--                                -->
    <allow own="net.iitdvpn.backends"/>

    <allow send_destination="net.iitdvpn.backends"
           send_interface="net.iitdvpn.backends"
           send_path="/net/iitdvpn/backends"
           send_type="method_call"
           send_member="StartClient"/>

    <allow send_destination="net.iitdvpn.backends"
           send_interface="org.freedesktop.DBus.Peer"
           send_type="method_call"
           send_member="Ping"/>
  </policy>
</busconfig>
